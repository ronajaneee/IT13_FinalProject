<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="IT13_FinalProject.DashboardView">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">
            <Label Text="Dashboard Overview"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1e2445"
                   HorizontalOptions="Center" />
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="18" RowSpacing="18">
                <!-- Bookings Card -->
                <Frame Grid.Column="0" Grid.Row="0" BackgroundColor="#FF4B91" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Bookings" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="120" FontSize="32" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Today" FontSize="14" TextColor="WhiteSmoke" />
                        <Label Text="+5% vs yesterday" FontSize="12" TextColor="#FFB84B" />
                    </VerticalStackLayout>
                </Frame>
                <!-- Customers Card -->
                <Frame Grid.Column="1" Grid.Row="0" BackgroundColor="#2D3748" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Customers" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="350" FontSize="32" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Active" FontSize="14" TextColor="WhiteSmoke" />
                        <Label Text="+25 new this month" FontSize="12" TextColor="#10b981" />
                    </VerticalStackLayout>
                </Frame>
                <!-- Staff Activity Card -->
                <Frame Grid.Column="2" Grid.Row="0" BackgroundColor="#1e2445" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Staff Activity" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="5" FontSize="32" FontAttributes="Bold" TextColor="White" />
                        <Label Text="On Duty" FontSize="14" TextColor="WhiteSmoke" />
                        <Label Text="2 on break" FontSize="12" TextColor="#FFB84B" />
                    </VerticalStackLayout>
                </Frame>
                <!-- Sales Card -->
                <Frame Grid.Column="0" Grid.Row="1" BackgroundColor="#FFB84B" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Sales" FontSize="18" FontAttributes="Bold" TextColor="#1e2445" />
                        <Label Text="$2,500" FontSize="32" FontAttributes="Bold" TextColor="#1e2445" />
                        <Label Text="This Month" FontSize="14" TextColor="#1e2445" />
                        <StackLayout Orientation="Horizontal" Spacing="8" VerticalOptions="Center">
                            <Label Text="Target: $3,500" FontSize="12" TextColor="#1e2445" />
                            <ProgressBar x:Name="SalesProgressBar" Progress="0.71" HeightRequest="8" WidthRequest="80" BackgroundColor="#fff" />
                        </StackLayout>
                    </VerticalStackLayout>
                </Frame>
                <!-- Notifications Card -->
                <Frame Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" BackgroundColor="#2D3748" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Notifications" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Label Text="💬" FontSize="16" />
                            <Label Text="3 new messages" FontSize="16" TextColor="WhiteSmoke" />
                        </StackLayout>
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Label Text="📅" FontSize="16" />
                            <Label Text="2 upcoming appointments" FontSize="16" TextColor="WhiteSmoke" />
                        </StackLayout>
                        <!-- Today's reminders -->
                        <BoxView HeightRequest="1" Color="#FFB84B" Margin="0,8,0,8" />
                        <Label Text="Today's reminders" FontSize="14" FontAttributes="Bold" TextColor="#FFB84B" />
                        <Label Text="Customer birthday 🎂" FontSize="13" TextColor="WhiteSmoke" />
                        <Label Text="Low stock alert 🚨 (Massage oil running low)" FontSize="13" TextColor="WhiteSmoke" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Analytics Section: Bookings Bar Chart & Revenue Line Chart -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="18" Margin="0,12,0,0">
                <Frame Grid.Column="0" BackgroundColor="#fff" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Bookings (Mon–Sun)" FontSize="16" FontAttributes="Bold" TextColor="#1e2445" />
                        <microcharts:ChartView Chart="{Binding BookingsBarChart}" HeightRequest="160" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" BackgroundColor="#fff" CornerRadius="16" Padding="18" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="Revenue (Last 4 Weeks)" FontSize="16" FontAttributes="Bold" TextColor="#1e2445" />
                        <microcharts:ChartView Chart="{Binding RevenueLineChart}" HeightRequest="160" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Customer Insights Section -->
            <Frame BackgroundColor="#fff" CornerRadius="16" Padding="18" HasShadow="True" Margin="0,12,0,0">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                    <VerticalStackLayout>
                        <Label Text="Customer Insights" FontSize="16" FontAttributes="Bold" TextColor="#1e2445" />
                        <StackLayout Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                            <Frame BackgroundColor="#10b981" CornerRadius="8" Padding="8" HasShadow="False">
                                <Label Text="New Customers: 40" FontSize="14" TextColor="White" />
                            </Frame>
                            <Frame BackgroundColor="#4B91FF" CornerRadius="8" Padding="8" HasShadow="False">
                                <Label Text="Returning Customers: 310" FontSize="14" TextColor="White" />
                            </Frame>
                        </StackLayout>
                    </VerticalStackLayout>
                    <microcharts:ChartView Grid.Column="1" Chart="{Binding CustomerPieChart}" HeightRequest="80" WidthRequest="80" />
                </Grid>
            </Frame>

            <!-- Staff Activity Section -->
            <Frame BackgroundColor="#fff" CornerRadius="16" Padding="18" HasShadow="True" Margin="0,12,0,0">
                <VerticalStackLayout>
                    <Label Text="Staff On Duty" FontSize="16" FontAttributes="Bold" TextColor="#1e2445" />
                    <StackLayout Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                        <!-- Example staff list -->
                        <VerticalStackLayout>
                            <Image Source="anna_profile.png" HeightRequest="40" WidthRequest="40" />
                            <Label Text="Anna – Massage (2 sessions)" FontSize="13" TextColor="#1e2445" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Image Source="john_profile.png" HeightRequest="40" WidthRequest="40" />
                            <Label Text="John – Facial (1 session)" FontSize="13" TextColor="#1e2445" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Image Source="mia_profile.png" HeightRequest="40" WidthRequest="40" />
                            <Label Text="Mia – Reception Desk" FontSize="13" TextColor="#1e2445" />
                        </VerticalStackLayout>
                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Appointments List Section -->
            <Frame BackgroundColor="#fff" CornerRadius="16" Padding="18" HasShadow="True" Margin="0,12,0,0">
                <VerticalStackLayout>
                    <Label Text="Upcoming Appointments" FontSize="16" FontAttributes="Bold" TextColor="#1e2445" />
                    <Grid ColumnDefinitions="2*,2*,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4" Margin="0,8,0,0">
                        <Label Grid.Column="0" Grid.Row="0" Text="Customer Name" FontAttributes="Bold" FontSize="13" TextColor="#4B91FF" />
                        <Label Grid.Column="1" Grid.Row="0" Text="Service" FontAttributes="Bold" FontSize="13" TextColor="#4B91FF" />
                        <Label Grid.Column="2" Grid.Row="0" Text="Time" FontAttributes="Bold" FontSize="13" TextColor="#4B91FF" />
                        <Label Grid.Column="3" Grid.Row="0" Text="Status" FontAttributes="Bold" FontSize="13" TextColor="#4B91FF" />
                        <!-- Example rows -->
                        <Label Grid.Column="0" Grid.Row="1" Text="Alice Smith" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="1" Grid.Row="1" Text="Massage" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="2" Grid.Row="1" Text="10:00 AM" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="3" Grid.Row="1" Text="Confirmed" FontSize="13" TextColor="#10b981" />
                        <Label Grid.Column="0" Grid.Row="2" Text="Bob Lee" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="1" Grid.Row="2" Text="Facial" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="2" Grid.Row="2" Text="11:30 AM" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="3" Grid.Row="2" Text="Pending" FontSize="13" TextColor="#FF4B91" />
                        <Label Grid.Column="0" Grid.Row="3" Text="Cathy Brown" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="1" Grid.Row="3" Text="Manicure" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="2" Grid.Row="3" Text="1:00 PM" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="3" Grid.Row="3" Text="Confirmed" FontSize="13" TextColor="#10b981" />
                        <Label Grid.Column="0" Grid.Row="4" Text="David Kim" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="1" Grid.Row="4" Text="Pedicure" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="2" Grid.Row="4" Text="2:30 PM" FontSize="13" TextColor="#1e2445" />
                        <Label Grid.Column="3" Grid.Row="4" Text="Pending" FontSize="13" TextColor="#FF4B91" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
